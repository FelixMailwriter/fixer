<odoo>
    <record id="fixer_workman_form" model="ir.ui.view">
        <field name="name">fixer.workman.form</field>
        <field name="model">fixer.workman</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string = "Данные сотрудника">
                            <field name="employee_id"/>
                            <field name="user_id"/>
                            <field name="name"/>
                            <field name="mobile_phone"/>
                            <field name="work_phone"/>
                            <field name="job_title"/>
                            <field name="age"/>
                        </group>
                        <group string="Photo">
                            <field name="image_1920" widget="image" class="oe_avatar"/>
                        </group>
                    </group>

                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_workman_tree" model="ir.ui.view">
        <field name="name">fixer.workman.tree</field>
        <field name="model">fixer.workman</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="mobile_phone"/>
                <field name="work_phone"/>
                <field name="description"/>
                <field name="job_title"/>
                <field name="age"/>
            </tree>
        </field>
    </record>

    <record id="action_fixer_workman" model="ir.actions.act_window">
        <field name="name">Workmen</field>
        <field name="res_model">fixer.workman</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- <menuitem id="fixer_menu_workmen" name="Работники" parent="fixer_menu_root" action="action_fixer_workman"/> -->
</odoo>