<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="fixer_order_form" model="ir.ui.view">
        <field name="name">fixer.order.form</field>
        <field name="model">fixer.order</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Основная информация">
                            <field name="name"/>
                            <field name="order_type"/>
                            <field name="client_id"/>
                            <field name="equipment_id"/>
                            <field name="user_id"/>
                        </group>
                    </group>

                    <!-- Монтаж -->
                    <group string="Монтаж" invisible="order_type != 'installation'">
                        <group>
                            <field name="install_track_length"/>
                            <field name="install_height"/>
                            <field name="install_mount_type"/>
                        </group>
                        <group>
                            <field name="install_copper_pipe"/>
                            <field name="install_cable"/>
                            <field name="install_fasteners"/>
                        </group>
                    </group>

                    <!-- Ремонт -->
                    <group string="Ремонт" invisible="order_type != 'repair'">
                        <group>
                            <field name="repair_symptoms"/>
                            <field name="repair_diagnosis"/>
                            <field name="repair_parts"/>
                        </group>
                        <group>
                            <field name="repair_photo_before" widget="image"/>
                            <field name="repair_photo_after" widget="image"/>
                        </group>
                    </group>

                    <!-- Заправка -->
                    <group string="Заправка" invisible="order_type != 'refill'">
                        <group>
                            <field name="refrigerant_type"/>
                            <field name="refrigerant_amount"/>
                        </group>
                        <group>
                            <field name="pressure_before"/>
                            <field name="pressure_after"/>
                        </group>
                    </group>

                    <!-- Плановое ТО -->
                    <group string="Чеклист ТО" invisible="order_type != 'maintenance'">
                        <group>
                            <field name="check_filters"/>
                            <field name="check_pressure"/>
                            <field name="check_electrical"/>
                        </group>
                        <group>
                            <field name="check_condensate"/>
                            <field name="check_test"/>
                        </group>
                    </group>

                    <!-- Гарантийный -->
                    <group string="Гарантийный случай" invisible="order_type != 'warranty'">
                        <field name="warranty_case"/>
                        <field name="is_free"/>
                    </group>

                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_order_tree" model="ir.ui.view">
        <field name="name">fixer.order.tree</field>
        <field name="model">fixer.order</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="order_type"/>
                <field name="client_id"/>
                <field name="equipment_id"/>
                <field name="user_id"/>
            </tree>
        </field>
    </record>

    <record id="action_fixer_order" model="ir.actions.act_window">
        <field name="name">Заказы-наряды</field>
        <field name="res_model">fixer.order</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
