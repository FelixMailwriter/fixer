<odoo>
    <record id="fixer_jobtype_form" model="ir.ui.view">
        <field name="name">fixer.jobtype.form</field>
        <field name="model">fixer.jobtype</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_jobtype_tree" model="ir.ui.view">
        <field name="name">fixer.jobtype.tree</field>
        <field name="model">fixer.jobtype</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="fixer_jobtype_action" model="ir.actions.act_window">
        <field name="name">Job Types</field>
        <field name="res_model">fixer.jobtype</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- <menuitem id="fixer_menu_jobtypes" name="Типы работ" parent="fixer_menu_root" action="fixer_jobtype_action"/> -->
</odoo>