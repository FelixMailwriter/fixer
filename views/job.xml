<odoo>
    <record id="fixer_job_form" model="ir.ui.view">
        <field name="name">fixer.job.form</field>
        <field name="model">fixer.job</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_job_tree" model="ir.ui.view">
        <field name="name">fixer.job.tree</field>
        <field name="model">fixer.job</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="action_fixer_job" model="ir.actions.act_window">
        <field name="name">Заявки</field>
        <field name="res_model">fixer.job</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- <menuitem id="fixer_menu_jobs" name="Работы" parent="fixer_menu_root" action="action_fixer_job"/> -->
</odoo>