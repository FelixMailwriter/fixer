<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="fixer_order_type_form" model="ir.ui.view">
        <field name="name">fixer.order.type.form</field>
        <field name="model">fixer.order.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="fixer_order_type_tree" model="ir.ui.view">
        <field name="name">fixer.order.type.tree</field>
        <field name="model">fixer.order.type</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
            </tree>
        </field>
    </record>

    <record id="action_fixer_order_type" model="ir.actions.act_window">
        <field name="name">Типы заказов</field>
        <field name="res_model">fixer.order.type</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
